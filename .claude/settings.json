{
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm audit)",
      "Bash(npm run setup)",
      "Bash(npm run setup -- --dry-run)",
      "Bash(npm test)",
      "Bash(npm run test:*)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run dev:api)",
      "Bash(npm run preview)",
      "Bash(npm run docs:*)",
      "Bash(npm run perf:monitor)",
      "Bash(npm run security:scan)",
      "Bash(npm run security:scan:all)",
      "Bash(npm run security:hooks)",
      "Bash(npx playwright install*)",
      "Bash(node scripts/*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git config core.hooksPath*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(chmod 777 *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(sudo *)",
      "Bash(ssh *)",
      "Bash(* > /dev/*)"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/precompact-context.mjs",
            "statusMessage": "Saving compaction context..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-protected-writes.mjs"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-dangerous-bash.mjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/lint-on-save.mjs",
            "statusMessage": "Linting..."
          },
          {
            "type": "command",
            "command": "node .claude/hooks/post-edit-reviews.mjs",
            "statusMessage": "Checking review triggers..."
          },
          {
            "type": "command",
            "command": "node .claude/hooks/js-syntax-check.mjs",
            "statusMessage": "Checking JS syntax..."
          },
          {
            "type": "command",
            "command": "git status --short",
            "statusMessage": "Checking git status..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/stop-sensitive-check.mjs"
          }
        ]
      }
    ]
  }
}
