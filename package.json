{
  "name": "casedive",
  "private": true,
  "version": "1.0.0",
  "packageManager": "npm@11.11.0",
  "description": "AI-powered Canadian legal research tool",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "vercel dev",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest run --exclude tests/unit/**/*.test.jsx",
    "test:component": "vitest run tests/unit/*.test.jsx",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:live": "PLAYWRIGHT_MODE=live playwright test",
    "test:filter": "node scripts/tune-filters.js --report",
    "test:filter:keyed": "node scripts/tune-filters.js --report --require-key",
    "test:filter:calibrate": "node scripts/tune-filters.js --require-key --calibrate",
    "test:filter:baseline": "node scripts/tune-filters.js --baseline",
    "test:filter:compare": "node scripts/tune-filters.js --compare",
    "test:retrieval-failures": "node scripts/evaluate-retrieval-failures.js",
    "test:retrieval-failures:baseline": "node scripts/evaluate-retrieval-failures.js --baseline",
    "test:retrieval-failures:compare": "node scripts/evaluate-retrieval-failures.js --compare",
    "test:guardrails": "vitest run tests/unit/resultCardSanitizer.test.js && npm run test:retrieval-failures && npm run test:filter",
    "test:security": "vitest run tests/unit/rateLimit.test.js tests/unit/analyzeApi.test.js tests/unit/retrievalHealth.test.js tests/unit/canlii.test.js tests/unit/securityConfig.test.js tests/unit/resultCardSanitizer.test.js",
    "perf:monitor": "node scripts/performance-monitor.js",
    "docs:build": "node scripts/docs-build.js",
    "docs:preview": "node scripts/docs-preview.js",
    "docs:lint": "markdownlint-cli2 \"reports/**/*.md\" \"artifacts/**/*.md\" \"docs/superpowers/**/*.md\"",
    "security:scan": "gitleaks git . --log-opts='--branches --tags' --redact --no-banner",
    "security:scan:all": "gitleaks git . --log-opts='--all' --redact --no-banner",
    "security:hooks": "bash scripts/setup-git-hooks.sh"
  },
  "dependencies": {
    "@sentry/node": "^10.46.0",
    "@sentry/react": "^10.46.0",
    "@upstash/redis": "1.38.0",
    "@vercel/analytics": "^2.0.1",
    "pdfkit": "^0.18.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser": "^4.1.7",
    "browser-sync": "^3.0.4",
    "happy-dom": "^20.8.8",
    "jsdom": "^29.0.1",
    "markdownlint-cli2": "^0.22.1",
    "marked": "^18.0.4",
    "vite": "^6.4.2",
    "vitest": "^4.1.7"
  }
}
